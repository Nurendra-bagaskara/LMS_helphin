        uuid prodi_id FK
        uuid created_by FK
        timestamp created_at
    }

    MATERIAL_REQUEST {
        uuid id PK
        string title
        string subject
        string description
        uuid student_id FK
        uuid prodi_id FK
        timestamp created_at
